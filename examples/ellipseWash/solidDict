FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      solids;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

meta
{
  on_fluid 1;
  on_twod  1;
  gravity  (0.0 -9.8 0.0);
  Cpenalty 2000.0;              // penalty factor for IBM
  // Cpenalty 10.0;
}
  
shapes
{
    shape1
    {
        name circle1;
        type Circle;
        // radius 1.0;
        radius 0.5;
    }
    shape2
    {
        name ellipse1;
        type Ellipse;
        radiusa 0.8;
        radiusb 0.4;
    }
}

materials
{
    material1
    {
      name mat1;
      type General;
      rho 1.0;
      rn 0.9;
      rt 0.9;
    }
    material2
    {
      name xeonite;
      type General;
      rho 3000.0;
    }
}

motions
{
    motion1
    {
      name static1;
      type Motion01Mask;
      mask b000000;
    }
    motion2
    {
      name sixDofFree;
      type Motion01Mask;
      mask b111111;
    }
}

solids
{
    solid1
    {
      shp_name ellipse1;
      // shp_name circle1;
      mat_name xeonite;
      // mot_name sixDofFree;
      mot_name static1;
      // pos (1.5 2.0 0.0);
      pos (1.5 1.0 0.0);
      vel (0.0 0.0 0.0);
      euler (0.0 0.0 45.0);
    }
}

planes {}
